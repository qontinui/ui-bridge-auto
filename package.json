{
  "name": "@qontinui/ui-bridge-auto",
  "version": "0.1.6",
  "description": "DOM-based model-based automation library for the UI Bridge SDK",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qontinui/ui-bridge-auto.git"
  },
  "homepage": "https://github.com/qontinui/ui-bridge-auto#readme",
  "bugs": {
    "url": "https://github.com/qontinui/ui-bridge-auto/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types/index.d.mts",
        "default": "./dist/types/index.mjs"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types/index.js"
      }
    },
    "./drift": {
      "import": {
        "types": "./dist/drift/index.d.mts",
        "default": "./dist/drift/index.mjs"
      },
      "require": {
        "types": "./dist/drift/index.d.ts",
        "default": "./dist/drift/index.js"
      }
    },
    "./drift/node": {
      "import": {
        "types": "./dist/drift/node.d.mts",
        "default": "./dist/drift/node.mjs"
      },
      "require": {
        "types": "./dist/drift/node.d.ts",
        "default": "./dist/drift/node.js"
      }
    },
    "./regression": {
      "import": {
        "types": "./dist/regression/index.d.mts",
        "default": "./dist/regression/index.mjs"
      },
      "require": {
        "types": "./dist/regression/index.d.ts",
        "default": "./dist/regression/index.js"
      }
    },
    "./diagnosis": {
      "import": {
        "types": "./dist/diagnosis/index.d.mts",
        "default": "./dist/diagnosis/index.mjs"
      },
      "require": {
        "types": "./dist/diagnosis/index.d.ts",
        "default": "./dist/diagnosis/index.js"
      }
    },
    "./visual": {
      "import": {
        "types": "./dist/visual/index.d.mts",
        "default": "./dist/visual/index.mjs"
      },
      "require": {
        "types": "./dist/visual/index.d.ts",
        "default": "./dist/visual/index.js"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime/index.d.mts",
        "default": "./dist/runtime/index.mjs"
      },
      "require": {
        "types": "./dist/runtime/index.d.ts",
        "default": "./dist/runtime/index.js"
      }
    },
    "./ir-builder": {
      "import": {
        "types": "./dist/ir-builder/index.d.mts",
        "default": "./dist/ir-builder/index.mjs"
      },
      "require": {
        "types": "./dist/ir-builder/index.d.ts",
        "default": "./dist/ir-builder/index.js"
      }
    }
  },
  "bin": {
    "ui-bridge-build-ir": "./dist/ir-builder/cli.cjs"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsup && node scripts/check-dts-completeness.js",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "verify-published": "node scripts/verify-published.js"
  },
  "dependencies": {
    "@qontinui/shared-types": "^0.2.1",
    "@qontinui/ui-bridge": "^0.3.2",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.0",
    "ws": "^8.20.0"
  },
  "peerDependencies": {
    "tesseract.js": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "tesseract.js": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "license": "AGPL-3.0-or-later"
}
